#!/usr/bin/env bash
# SessionStart hook for JDS plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read jds-bootstrap content
jds_bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/jds-bootstrap/SKILL.md" 2>&1 || echo "Error reading jds-bootstrap skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

jds_bootstrap_escaped=$(escape_for_json "$jds_bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have JDS (Jopa Development Superpowers).\n\n**Below is the full content of your 'jds:jds-bootstrap' skill — your introduction to the JDS workflow :**\n\n${jds_bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"

exit 0
